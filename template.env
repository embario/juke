### Runtime profile (required)
# Select deployment behavior for backend/web containers.
JUKE_RUNTIME_ENV=development
DJANGO_SECRET_KEY=dummy-secret-key-for-development

### Host ports (required)
BACKEND_PORT=8000
WEB_PORT=5173
RECOMMENDER_PORT=9000
REDIS_PORT=6379
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

### Internal ports (required)
POSTGRES_PORT=5432
EMAIL_PORT=587

### Public URLs (required)
# These must match the host ports above.
# FRONTEND_URL is used for email verification/reset links and auth redirects.
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

### Database (required)
POSTGRES_NAME=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

### Redis / Celery (required)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Seconds Redis keeps leased Celery tasks invisible before they are redelivered.
CELERY_VISIBILITY_TIMEOUT=3600

### Recommender engine (required)
RECOMMENDER_ENGINE_BASE_URL=http://recommender-engine:9000
RECOMMENDER_ENGINE_TIMEOUT=15
RECOMMENDER_MODEL_VERSION=v1.0.0
RECOMMENDER_VECTOR_DIM=32

### ML Core — corpus governance (backend)
# Controls which CorpusManifest rows LicensePolicy.eligible_queryset() admits
# as training/embedding inputs. Modes:
#   production — only production_approved sources AND allowed_envs in {production, both}.
#                Use for anything whose output reaches end users.
#   research   — only allowed_envs in {research, both}. Use for local notebooks,
#                one-off evals, throwaway experiments. The promotion guard will
#                still block any model trained this way from activating in prod.
#   both       — all rows with non-blank license. Reconciliation/tooling only;
#                never for training something that might be deployed.
JUKE_ALLOWED_LICENSES=production
# When 1, any source NOT listed in SOURCE_CLASSIFICATION is classified as
# 'blocked' (rejected outright). When 0, unknown sources become 'research_only'
# (usable in research mode only). Production mode rejects non-approved sources
# regardless of this flag — it only widens the research-mode window.
# Keep this on (1) unless you are intentionally trialling an unvetted dataset.
JUKE_LICENSE_FAIL_CLOSED=1

### Juke World (optional)
# Seed synthetic globe users on backend startup (0 to disable).
JUKE_WORLD_SEED_COUNT=0

### Auth, Provider Auth, & Email (required for auth flows)
EMAIL_HOST_USER=jukedotmusic@gmail.com
EMAIL_HOST_PASSWORD=host-password
SOCIAL_AUTH_SPOTIFY_KEY=some-super-secret-social-auth-key
SOCIAL_AUTH_SPOTIFY_SECRET=some-super-secret-social-auth-secret
# Unified Spotify scopes for backend-managed playback control.
SOCIAL_AUTH_SPOTIFY_SCOPE="user-read-playback-state user-read-currently-playing user-modify-playback-state"
# Allowed mobile/custom return URI schemes for /api/v1/auth/connect/spotify/.
SPOTIFY_CONNECT_ALLOWED_RETURN_SCHEMES=juke,shotclock
# Throttle for issuing short-lived Spotify access tokens at /api/v1/auth/spotify/token/.
SPOTIFY_TOKEN_ISSUE_RATE=30/min
DISABLE_REGISTRATION=0

### OpenAI (required for TuneTrivia trivia generation)
OPENAI_API_KEY=
TUNETRIVIA_TRIVIA_MODEL=gpt-4o-mini

### Networking and hosts (optional)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,web
DOCKER_NETWORK_NAME=
