### Runtime profile (required)
# Select deployment behavior for backend/web containers.
JUKE_RUNTIME_ENV=development
DJANGO_SECRET_KEY=dummy-secret-key-for-development

### Host ports (required)
BACKEND_PORT=8000
WEB_PORT=5173
RECOMMENDER_PORT=9000
REDIS_PORT=6379
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

### Internal ports (required)
POSTGRES_PORT=5432
EMAIL_PORT=587

### Public URLs (required)
# These must match the host ports above.
# FRONTEND_URL is used for email verification/reset links and auth redirects.
# PUBLIC_BACKEND_URL is the browser-visible backend origin used for Spotify OAuth.
BACKEND_URL=http://localhost:8000
PUBLIC_BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://neptune:5173
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://neptune:5173

### Database (required)
POSTGRES_NAME=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Postgres WAL budget for bulk-ingest workloads. Larger values reduce forced checkpoints
# during ListenBrainz backfills at the cost of more disk reserved for WAL recycling.
POSTGRES_MAX_WAL_SIZE=16GB

### Redis / Celery (required)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Seconds Redis keeps leased Celery tasks invisible before they are redelivered.
CELERY_VISIBILITY_TIMEOUT=3600
# Total Celery execution slots available in the worker pool. Keep this higher than
# shard parallelism so the orchestration task does not consume the only worker slot.
CELERY_WORKER_TOTAL_SLOTS=5

### Recommender engine (required)
RECOMMENDER_ENGINE_BASE_URL=http://recommender-engine:9000
RECOMMENDER_ENGINE_TIMEOUT=15
RECOMMENDER_MODEL_VERSION=v1.0.0
RECOMMENDER_VECTOR_DIM=32

### ML Core — corpus governance (backend)
# Controls which CorpusManifest rows LicensePolicy.eligible_queryset() admits
# as training/embedding inputs. Modes:
#   production — only production_approved sources AND allowed_envs in {production, both}.
#                Use for anything whose output reaches end users.
#   research   — only allowed_envs in {research, both}. Use for local notebooks,
#                one-off evals, throwaway experiments. The promotion guard will
#                still block any model trained this way from activating in prod.
#   both       — all rows with non-blank license. Reconciliation/tooling only;
#                never for training something that might be deployed.
JUKE_ALLOWED_LICENSES=production
# When 1, any source NOT listed in SOURCE_CLASSIFICATION is classified as
# 'blocked' (rejected outright). When 0, unknown sources become 'research_only'
# (usable in research mode only). Production mode rejects non-approved sources
# regardless of this flag — it only widens the research-mode window.
# Keep this on (1) unless you are intentionally trialling an unvetted dataset.
JUKE_LICENSE_FAIL_CLOSED=1
# ListenBrainz dump locations used by MLCore file-based ingestion (`.tar`,
# `.tar.gz`, `.tgz`, `.tar.zst`, `.gz`, or plain JSON-lines).
# Leave blank unless you are actively importing external behavioral data.
MLCORE_LISTENBRAINZ_FULL_IMPORT_PATH=
MLCORE_LISTENBRAINZ_INCREMENTAL_IMPORT_PATH=
# Optional explicit source-version labels. If blank, MLCore uses the dump filename.
MLCORE_LISTENBRAINZ_FULL_SOURCE_VERSION=
MLCORE_LISTENBRAINZ_INCREMENTAL_SOURCE_VERSION=
# Official remote dump root used by the scheduled MLCore sync task.
MLCORE_LISTENBRAINZ_REMOTE_ROOT_URL=https://ftp.musicbrainz.org/pub/musicbrainz/listenbrainz/
# Writable directory where backend/worker stage remote dumps before import.
MLCORE_LISTENBRAINZ_DOWNLOAD_DIR=/srv/data/backups/juke/listenbrainz
# Remote index/download timeout in seconds.
MLCORE_LISTENBRAINZ_REMOTE_TIMEOUT_SECONDS=60
# Periodic sync cadence for discovering new remote dumps.
MLCORE_LISTENBRAINZ_REMOTE_SYNC_SCHEDULE_SECONDS=86400
# Safety valve to bound backfill work per sync run after a new full dump lands.
MLCORE_LISTENBRAINZ_REMOTE_SYNC_MAX_INCREMENTALS_PER_RUN=14
# Default shard fan-out target for one orchestrated dataset ingestion run.
MLCORE_DATASET_SHARD_PARALLELISM=4
# Optional limit on how many shards one orchestrated run schedules. 0 means all shards.
MLCORE_DATASET_MAX_SHARDS_PER_RUN=0
# Seconds without shard progress before a running shard is marked stale and eligible for resume.
MLCORE_DATASET_ORCHESTRATION_STALE_TIMEOUT_SECONDS=1800
# Poll interval for the orchestration task while aggregating shard progress.
MLCORE_DATASET_ORCHESTRATION_POLL_SECONDS=5
# Log interval for aggregate orchestration heartbeats in worker logs.
MLCORE_DATASET_ORCHESTRATION_LOG_SECONDS=300
# 0 = fail on the first malformed row. Increase only when triaging a known-bad dump.
MLCORE_LISTENBRAINZ_MAX_MALFORMED_ROWS=0
# Salt used when hashing external source user IDs before persistence.
MLCORE_LISTENBRAINZ_USER_HASH_SALT=listenbrainz
# Sessionization window for normalized ListenBrainz interactions, in seconds.
MLCORE_LISTENBRAINZ_SESSION_WINDOW_SECONDS=1800
# PostgreSQL tablespace host locations used by MLCore migration `0008` / `0009`.
# The admin/operator chooses the host storage roots below. Docker Compose bind-mounts
# them into the `db` container at fixed internal paths:
#   /var/lib/postgresql/tablespaces/juke_mlcore_hot
#   /var/lib/postgresql/tablespaces/juke_mlcore_cold
# The migration creates fixed tablespaces named:
#   juke_mlcore_hot
#   juke_mlcore_cold
# These paths must be absolute filesystem paths on the host.
MLCORE_PG_HOT_TABLESPACE_HOST_PATH=
MLCORE_PG_COLD_TABLESPACE_HOST_PATH=

### Juke World (optional)
# Seed synthetic globe users on backend startup (0 to disable).
JUKE_WORLD_SEED_COUNT=0

### Auth, Provider Auth, & Email (required for auth flows)
EMAIL_HOST_USER=jukedotmusic@gmail.com
EMAIL_HOST_PASSWORD=host-password
SOCIAL_AUTH_SPOTIFY_KEY=some-super-secret-social-auth-key
SOCIAL_AUTH_SPOTIFY_SECRET=some-super-secret-social-auth-secret
# Unified Spotify scopes for backend-managed playback control.
SOCIAL_AUTH_SPOTIFY_SCOPE="user-read-playback-state user-read-currently-playing user-modify-playback-state"
# Allowed mobile/custom return URI schemes for /api/v1/auth/connect/spotify/.
SPOTIFY_CONNECT_ALLOWED_RETURN_SCHEMES=juke,shotclock
# Throttle for issuing short-lived Spotify access tokens at /api/v1/auth/spotify/token/.
SPOTIFY_TOKEN_ISSUE_RATE=30/min
DISABLE_REGISTRATION=0

### OpenAI (required for TuneTrivia trivia generation)
OPENAI_API_KEY=
TUNETRIVIA_TRIVIA_MODEL=gpt-4o-mini

### Networking and hosts (optional)
BACKEND_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,web,backend
WEB_ALLOWED_HOSTS=localhost,127.0.0.1
DOCKER_NETWORK_NAME=
